<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissões básicas (WebView / rede) -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- Necessária para instalar APKs fora da Play (Android 8+) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

    <!-- Android 13+ (Tiramisu) precisa da permissão de notificação em runtime -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:label="Futanium Box Players"
		    android:icon="@mipmap/ic_launcher"
		    android:roundIcon="@mipmap/ic_launcher"
        android:hardwareAccelerated="true"
        android:allowBackup="true"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Material3.DayNight.NoActionBar">

        <!-- FileProvider para entregar o APK ao instalador -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

        <!-- (Opcional) legado; pode manter se já estava usando -->
        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />

        <activity
            android:name=".WebViewActivity"
            android:hardwareAccelerated="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Futanium.Fullscreen"
            android:exported="false" />
     
        <activity
    android:name=".ExternalWebViewActivity"
    android:exported="false"
    android:hardwareAccelerated="true"
    android:screenOrientation="landscape"
    android:theme="@style/Theme.Futanium.Fullscreen" />

    <activity
    android:name=".YoutubeWebViewActivity"
    android:exported="false"
    android:hardwareAccelerated="true"
    android:screenOrientation="landscape"
    android:theme="@style/Theme.Futanium.Fullscreen" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowDisablePreview="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity
            android:name=".PlayerActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:resizeableActivity="false"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

				        <activity
            android:name=".AdWebViewActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <!-- 🔔 Service para receber mensagens do Firebase Cloud Messaging -->
        <service
            android:name=".push.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- 🔔 Configuração padrão de notificações (ícone e canal) -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_notify" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="futanium_channel" />
        
				 <meta-data
    android:name="android.support.customtabs.trusted.DEFAULT_URL"
    android:value="https://www.google.com" />

    </application>
</manifest>
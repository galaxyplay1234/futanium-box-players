<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Futanium" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Usa a mesma cor do menu/toolbar -->
        <item name="colorPrimary">@color/menuColor</item>
        <item name="colorPrimaryContainer">@color/menuColor</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Fundo e barras já na cor do app (sem flash roxo/branco) -->
        <item name="android:windowBackground">@color/startup_bg</item>
        <item name="android:statusBarColor">@color/startup_bg</item>
        <item name="android:navigationBarColor">@color/startup_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>

        <!-- Splash nativo “transparente” e alinhado ao fundo -->
        <item name="android:windowSplashScreenBackground">@color/startup_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
        <item name="android:windowSplashScreenBrandingImage">@null</item>
    </style>
</resources>